# MySQL (obrigatório)
DB_HOST=localhost
DB_PORT=3306
DB_USER=seu_usuario
DB_PASSWORD=sua_senha
DB_NAME=seu_banco

# Opcional: primeiro utilizador admin criado automaticamente se ainda não existir
ADMIN_EMAIL=admin@exemplo.com

# Segredo das sessões (obrigatório em produção; use string longa aleatória)
SESSION_SECRET=altere-para-uma-string-longa-aleatoria

# URL pública do site (usada no link mágico do e-mail). Em produção use https://seu-dominio.com
PUBLIC_BASE_URL=http://localhost:3001

# E-mail com acesso à área "Domínios" no admin (CRUD de domínios permitidos). Predefinição: comunicacao.saab@owly.com.br
# DOMAINS_ADMIN_EMAIL=comunicacao.saab@owly.com.br

# SMTP — envio do link mágico de login
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_REQUIRE_TLS=true
# SMTP_AUTH_METHOD=LOGIN
# SMTP_TLS_REJECT_UNAUTHORIZED=true
# SMTP_DEBUG=false
# SMTP_VERIFY_BEFORE_SEND=true

# Convert.io — conversão WebM → MP4
CONVERTIO_API_KEY=dd28dc0297536201fca386a45fe3b0e1

# Opcional
# PORT=3001
# NODE_ENV=production
